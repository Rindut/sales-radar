# Optional: call the Go API directly from the browser (different origin → CORS must allow your UI).
# Leave unset to use same-origin /api/v1/* (Next.js rewrites to the API — recommended for local dev).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Server-side rewrite target (Next → Go). Defaults to http://127.0.0.1:8080
# API_UPSTREAM=http://127.0.0.1:8080
